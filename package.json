    "date-fns": "^4.1.0",

    "i18next": "^23.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-i18next": "^14.0.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@babel/core": "^7.24.4",
    "@babel/parser": "^7.29.3",
    "@babel/plugin-transform-class-properties": "7.25.9",
    "@babel/preset-react": "^7.24.1",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@egoist/tailwindcss-icons": "^1.9.0",

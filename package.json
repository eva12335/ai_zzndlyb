    "@iconify-json/mdi": "^1.2.3",
    "@tailwindcss/postcss": "^4.1.18",
    "@tarojs/cli": "4.2.0",
    "@tarojs/plugin-generator": "4.2.0",
    "@tarojs/plugin-mini-ci": "^4.2.0",

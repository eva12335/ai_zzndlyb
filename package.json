{
  "name": "一人公司罗盘",
  "version": "1.0.0",
  "private": true,
  "description": "Meoo Mini Program Application",
  "meoo": {
    "api-url": "",
    "app-id": ""
  },
  "scripts": {
    "build": "pnpm build:weapp && rm -rf /mnt/c/Users/Public/ai_zzndlyb_dist && mkdir -p /mnt/c/Users/Public/ai_zzndlyb_dist/miniprogram && cp -r dist/* /mnt/c/Users/Public/ai_zzndlyb_dist/miniprogram/ && rm -f /mnt/c/Users/Public/ai_zzndlyb_dist/miniprogram/project.config.json && cp -r cloudfunctions /mnt/c/Users/Public/ai_zzndlyb_dist/miniprogram/ && cp project.config.build.json /mnt/c/Users/Public/ai_zzndlyb_dist/project.config.json",
    "build:weapp": "taro build --type weapp",
    "build:web": "taro build --type h5",
    "dev": "pnpm dev:web",
    "dev:weapp": "taro build --type weapp --watch",
    "dev:web": "taro build --type h5 --watch",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "weapp-tw patch",
    "new": "taro new",
    "preview:weapp": "taro build --type weapp --preview",
    "//validate": "项目唯一校验入口：并发跑 eslint(零警告) + tsc(类型检查)。查看输出务必完整读取，禁止用 head/tail 截断——错误可能出现在任意位置，截断会漏报。",
    "validate": "pnpm exec concurrently --kill-others-on-fail --kill-signal SIGKILL -n lint,tsc -c red,blue \"eslint 'src/**/*.{js,jsx,ts,tsx,css}' --max-warnings=0 --quiet\" \"tsc --noEmit --skipLibCheck\""
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx,css}": [
      "eslint"
    ]
  },
  "browserslist": [
    "last 3 versions",
    "Android >= 4.1",
    "ios >= 8"
  ],
  "dependencies": {
    "@babel/runtime": "^7.24.4",
    "@tarojs/components": "4.2.0",
    "@tarojs/helper": "4.2.0",
    "@tarojs/plugin-framework-react": "4.2.0",
    "@tarojs/plugin-platform-h5": "4.2.0",
    "@tarojs/plugin-platform-weapp": "4.2.0",
    "@tarojs/react": "4.2.0",
    "@tarojs/runtime": "4.2.0",
    "@tarojs/shared": "4.2.0",
    "@tarojs/taro": "4.2.0",
